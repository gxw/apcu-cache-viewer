{
    "name": "apcu/cache-viewer",
    "description": "APCu Cache Viewer",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "ext-apcu": "*",
        "symfony/var-dumper": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
